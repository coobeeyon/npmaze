{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "lb prime",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "lb prime",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(lb:*)"
    ]
  }
}